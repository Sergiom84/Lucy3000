{
  "name": "lucy3000-accounting",
  "version": "2.0.0",
  "description": "Sistema de contabilidad avanzado para tiendas de estética",
  "main": "dist/main/main.js",
  "author": "Sergio Hernández Lara",
  "license": "MIT",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-dev-ports.ps1",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:electron\"",
    "dev:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-backend.ps1",
    "dev:electron": "vite",
    "build": "npm run build:prepare-db && tsc && vite build && npm run build:backend && electron-builder",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:prepare-db": "node scripts/prepare-packaged-db.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/backend/unit",
    "test:smoke": "vitest run tests/backend/smoke",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.8.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.6",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "googleapis": "^140.0.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.303.0",
    "moment": "^2.30.1",
    "multer": "^2.1.1",
    "node-xlrd": "^0.3.10",
    "prisma": "^5.8.0",
    "react": "^18.2.0",
    "react-big-calendar": "^1.8.5",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.10.3",
    "tailwind-merge": "^2.2.0",
    "typescript": "^5.3.3",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.47",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "baseline-browser-mapping": "^2.10.19",
    "browserslist": "^4.28.2",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.1",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.lucy3000.accounting",
    "productName": "Lucy3000 Accounting",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "prisma/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/backend/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/@prisma/engines/**/*",
      "prisma/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/.prisma/client",
        "to": "app.asar.unpacked/node_modules/.prisma/client"
      },
      {
        "from": "prisma/schema.prisma",
        "to": "prisma/schema.prisma"
      },
      {
        "from": "prisma/migrations",
        "to": "prisma/migrations"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lucy3000",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  }
}
