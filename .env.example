# SQLite Database (local file)
# Prisma resolves this relative to prisma/schema.prisma -> prisma/prisma/lucy3000.db
DATABASE_URL="file:./prisma/lucy3000.db"

# Backend Configuration
PORT=3001
NODE_ENV=development

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App Configuration
APP_NAME="Lucy3000 Accounting"
APP_VERSION="1.0.0"

# Backup Configuration
BACKUP_PATH="./backups"
BACKUP_INTERVAL_HOURS=24

# Google Calendar Configuration
GOOGLE_CALENDAR_CLIENT_ID="your-google-client-id"
GOOGLE_CALENDAR_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3001/api/calendar/callback"

# WhatsApp Reminder Configuration (Meta WhatsApp Cloud API)
# Template variables expected order: 1) clientName 2) serviceName 3) appointmentDate 4) appointmentStartTime
WHATSAPP_REMINDERS_ENABLED=false
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_TEMPLATE_NAME="appointment_reminder"
WHATSAPP_TEMPLATE_LANGUAGE="es"
WHATSAPP_DEFAULT_COUNTRY_CODE="34"
WHATSAPP_GRAPH_API_VERSION="v23.0"
WHATSAPP_REMINDER_INTERVAL_MINUTES=30
