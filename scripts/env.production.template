# Lucy3000 - Production Client Configuration
# Copy this file as ".env" next to the Lucy3000 Accounting.exe only for the
# remote API wrapper. Do not put the shared Supabase DATABASE_URL on a client PC.

# API central. You can provide the origin or the /api URL.
LUCY3000_DATABASE_MODE=remote
LUCY3000_API_URL="https://api.tu-dominio.com/api"
VITE_API_URL="https://api.tu-dominio.com/api"

# Server
PORT=3001
NODE_ENV=production
