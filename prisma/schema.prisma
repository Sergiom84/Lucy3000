// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USUARIOS Y AUTENTICACION
// ============================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String?  @unique
  password      String
  name          String
  role          String   @default("EMPLOYEE")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  appointments  Appointment[]
  cashMovements CashMovement[]
  sales         Sale[]

  @@map("users")
}

// ============================================
// CLIENTES
// ============================================

model Client {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  email           String?   @unique
  phone           String
  birthDate       DateTime?
  address         String?
  city            String?
  postalCode      String?
  province        String?
  landlinePhone   String?
  mobilePhone     String?
  fullName        String?
  externalCode    String?
  dni             String?
  gender          String?
  registrationDate DateTime?
  esthetician     String?
  clientBrand     String?
  appliedTariff   String?
  text9A          String?
  text9B          String?
  text15          String?
  text25          String?
  text100         String?
  integer1        Int?
  integer2        Int?
  gifts           String?
  birthDay        Int?
  birthMonthNumber Int?
  birthMonthName  String?
  birthYear       Int?
  lastVisit       DateTime?
  serviceCount    Int?
  activeTreatmentCount Int?
  activeTreatmentNames String?
  bondCount       Int?
  giftVoucher     String?
  billedAmount    Decimal?
  pendingAmount   Decimal?
  debtAlertEnabled Boolean  @default(false)
  linkedClientReference String?
  relationshipType String?
  linkedClientId  String?
  discountProfile String?
  webKey          String?
  notes           String?
  allergies       String?
  photoUrl        String?
  loyaltyPoints   Int       @default(0)
  totalSpent      Decimal   @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accountBalance  Decimal?

  // Relaciones
  appointments    Appointment[]
  sales           Sale[]
  clientHistory   ClientHistory[]
  bonoPacks       BonoPack[]
  accountBalanceMovements AccountBalanceMovement[]
  quotes          Quote[]
  linkedClient    Client?   @relation("ClientLink", fields: [linkedClientId], references: [id], onDelete: SetNull)
  relatedClients  Client[]  @relation("ClientLink")

  @@map("clients")
}

model ClientHistory {
  id          String   @id @default(uuid())
  clientId    String
  date        DateTime @default(now())
  service     String
  notes       String?
  photoUrl    String?
  amount      Decimal

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_history")
}

// ============================================
// SERVICIOS
// ============================================

model Service {
  id              String   @id @default(uuid())
  name            String
  description     String?
  price           Decimal
  duration        Int      // en minutos
  category        String
  serviceCode     String?
  taxRate         Decimal?
  requiresProduct Boolean?
  commission      String?
  promo           String?
  legacyRole      String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  appointments    Appointment[]
  appointmentServices AppointmentService[]
  saleItems       SaleItem[]
  bonoPacks       BonoPack[]
  quoteItems      QuoteItem[]

  @@map("services")
}

// ============================================
// CITAS
// ============================================

model Appointment {
  id                       String   @id @default(uuid())
  clientId                 String?
  guestName                String?
  guestPhone               String?
  userId                   String
  serviceId                String
  cabin                    String   @default("LUCY")
  professional             String   @default("LUCY")
  date                     DateTime
  startTime                String
  endTime                  String
  status                   String   @default("SCHEDULED")
  notes                    String?
  reminder                 Boolean  @default(true)
  googleCalendarEventId    String?  @unique
  googleCalendarSyncStatus String   @default("DISABLED")
  googleCalendarSyncError  String?
  googleCalendarSyncedAt   DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
  service     Service  @relation(fields: [serviceId], references: [id])
  appointmentServices AppointmentService[]
  bonoSession BonoSession?
  sale        Sale?

  @@map("appointments")
}

model AppointmentService {
  appointmentId String
  serviceId     String
  sortOrder     Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([appointmentId, serviceId])
  @@unique([appointmentId, sortOrder])
  @@map("appointment_services")
}

model AppointmentLegend {
  id        String   @id @default(uuid())
  name      String
  color     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointment_legends")
}

model AgendaBlock {
  id                       String   @id @default(uuid())
  professional             String
  calendarInviteEmail      String?
  cabin                    String   @default("LUCY")
  date                     DateTime
  startTime                String
  endTime                  String
  notes                    String?
  googleCalendarEventId    String?  @unique
  googleCalendarSyncStatus String   @default("DISABLED")
  googleCalendarSyncError  String?
  googleCalendarSyncedAt   DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("agenda_blocks")
}

model AgendaDayNote {
  id          String   @id @default(uuid())
  dayKey       String
  text         String
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dayKey, createdAt])
  @@map("agenda_day_notes")
}

// ============================================
// PRODUCTOS Y ALMACEN
// ============================================

model Product {
  id              String   @id @default(uuid())
  name            String
  description     String?
  sku             String   @unique
  barcode         String?
  category        String
  brand           String?
  price           Decimal
  cost            Decimal
  stock           Int      @default(0)
  minStock        Int      @default(5)
  maxStock        Int?
  unit            String   @default("unidad")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  stockMovements  StockMovement[]
  saleItems       SaleItem[]
  quoteItems      QuoteItem[]

  @@map("products")
}

model StockMovement {
  id          String   @id @default(uuid())
  productId   String
  type        String
  quantity    Int
  reason      String?
  reference   String?
  date        DateTime @default(now())

  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

// ============================================
// VENTAS
// ============================================

model Sale {
  id              String   @id @default(uuid())
  clientId        String?
  appointmentId   String?  @unique
  userId          String
  professional    String   @default("LUCY")
  saleNumber      String   @unique
  date            DateTime @default(now())
  subtotal        Decimal
  discount        Decimal  @default(0)
  tax             Decimal  @default(0)
  total           Decimal
  paymentMethod   String
  showInOfficialCash Boolean @default(true)
  status          String   @default("COMPLETED")
  notes           String?

  client          Client?       @relation(fields: [clientId], references: [id])
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  user            User          @relation(fields: [userId], references: [id])
  items           SaleItem[]
  cashMovement    CashMovement?
  accountBalanceMovements AccountBalanceMovement[]

  @@map("sales")
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String?
  serviceId   String?
  description String
  quantity    Int
  price       Decimal
  subtotal    Decimal

  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])

  @@map("sale_items")
}

// ============================================
// CAJA
// ============================================

model CashRegister {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  openingBalance  Decimal
  closingBalance  Decimal?
  expectedBalance Decimal?
  difference      Decimal?
  status          String   @default("OPEN")
  notes           String?
  openedAt        DateTime @default(now())
  closedAt        DateTime?

  movements       CashMovement[]

  @@map("cash_registers")
}

model CashMovement {
  id              String   @id @default(uuid())
  cashRegisterId  String
  userId          String
  saleId          String?  @unique
  type            String
  paymentMethod   String?
  amount          Decimal
  category        String
  description     String
  reference       String?
  date            DateTime @default(now())

  cashRegister    CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id])
  sale            Sale?        @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@map("cash_movements")
}

model AccountBalanceMovement {
  id            String   @id @default(uuid())
  clientId      String
  saleId        String?
  type          String
  paymentMethod String?
  operationDate DateTime @default(now())
  description   String
  referenceItem String?
  legacyRef     String?
  importSource  String?
  amount        Decimal
  balanceAfter  Decimal
  notes         String?
  createdAt     DateTime @default(now())

  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sale          Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([clientId, operationDate])
  @@index([saleId])
  @@unique([clientId, legacyRef, importSource])
  @@map("account_balance_movements")
}

// ============================================
// NOTIFICACIONES
// ============================================

model Notification {
  id          String   @id @default(uuid())
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  priority    String   @default("NORMAL")
  createdAt   DateTime @default(now())

  @@map("notifications")
}

// ============================================
// CONFIGURACION
// ============================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// ============================================
// INTEGRACION GOOGLE CALENDAR
// ============================================

model GoogleCalendarConfig {
  id                String   @id @default(uuid())
  refreshToken      String
  calendarId        String   @default("primary")
  enabled           Boolean  @default(false)
  sendClientInvites Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("google_calendar_config")
}

// ============================================
// BONOS Y PACKS
// ============================================

model BonoPack {
  id             String   @id @default(uuid())
  clientId       String
  name           String
  serviceId      String?
  legacyRef      String?
  importSource   String?
  totalSessions  Int
  price          Decimal
  purchaseDate   DateTime @default(now())
  expiryDate     DateTime?
  status         String   @default("ACTIVE")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service        Service? @relation(fields: [serviceId], references: [id])
  sessions       BonoSession[]

  @@unique([clientId, legacyRef, importSource])
  @@map("bono_packs")
}

model BonoSession {
  id             String    @id @default(uuid())
  bonoPackId     String
  sessionNumber  Int
  status         String    @default("AVAILABLE")
  consumedAt     DateTime?
  appointmentId  String?   @unique
  notes          String?

  bonoPack       BonoPack     @relation(fields: [bonoPackId], references: [id], onDelete: Cascade)
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("bono_sessions")
}

// ============================================
// PRESUPUESTOS
// ============================================

model Quote {
  id              String   @id @default(uuid())
  quoteNumber     String   @unique
  clientId        String
  professional    String   @default("LUCY")
  date            DateTime @default(now())
  validUntil      DateTime
  subtotal        Decimal
  discount        Decimal  @default(0)
  total           Decimal
  status          String   @default("ISSUED")
  notes           String?
  createdAt       DateTime @default(now())

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items           QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(uuid())
  quoteId     String
  productId   String?
  serviceId   String?
  description String
  quantity    Int
  price       Decimal
  subtotal    Decimal

  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])

  @@map("quote_items")
}
